# --- Sanity (public read; same project as Studio) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=eff153ps
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: for draft content or higher API limits
# SANITY_API_READ_TOKEN=
# SANITY_API_VERSION=2024-01-01

# --- Supabase (server only; optional RAG via rag-query Edge Function) ---
# If both are set, /api/chat uses semantic search first; otherwise it uses GROQ.
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser or NEXT_PUBLIC_*.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude (server only; never NEXT_PUBLIC_) ---
ANTHROPIC_API_KEY=
# Optional model id — see https://docs.anthropic.com/en/docs/about-claude/models
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: simple shared secret for /api/chat (send same value as x-chat-access-token from the chat UI)
# CHAT_ACCESS_TOKEN=
