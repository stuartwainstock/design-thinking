# Copy to `.env.local` (or `.env`) and fill in values from the Supabase dashboard:
# Project Settings → API — https://supabase.com/dashboard/project/_/settings/api
#
# Never commit real keys. `service_role` bypasses RLS — use only in trusted server
# code, scripts, or CI, never in the browser or NEXT_PUBLIC_* vars.

# --- Core (any Node script or server) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Legacy name in dashboard is often "anon" / "public" — safe for clients when RLS is on
SUPABASE_ANON_KEY=

# --- Optional: service role (server / migrations / admin scripts only) ---
# SUPABASE_SERVICE_ROLE_KEY=

# --- If you add Next.js or another browser app, mirror the public values ---
# NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
# NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# --- Optional: project ref (handy for Supabase MCP / CLI linking) ---
# SUPABASE_PROJECT_REF=

# --- Sanity (optional; Studio usually reads sanity.config.ts — use for scripts / MCP) ---
# SANITY_STUDIO_PROJECT_ID=eff153ps
# SANITY_STUDIO_DATASET=production

# --- Next.js site (see web/.env.example for full list) ---
# Copy web/.env.example → web/.env.local for OPENAI_API_KEY and NEXT_PUBLIC_SANITY_*.
