# --- Sanity (public read; same project as Studio) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=eff153ps
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: for draft content or higher API limits
# SANITY_API_READ_TOKEN=
# SANITY_API_VERSION=2024-01-01

# --- Supabase (server only; optional RAG via rag-query Edge Function) ---
# If both are set, /api/chat uses semantic search first; otherwise it uses GROQ.
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser or NEXT_PUBLIC_*.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic Claude (server only; never NEXT_PUBLIC_) ---
ANTHROPIC_API_KEY=
# Optional model id — see https://docs.claude.com/en/docs/about-claude/models/overview
# Default in code is claude-sonnet-4-6. Deprecated example: claude-sonnet-4-20250514 (retired from API).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: simple shared secret for /api/chat (send same value as x-chat-access-token from the chat UI)
# CHAT_ACCESS_TOKEN=

# Executive admin dashboard at /admin/queries (send as x-admin-access-token from the browser)
# Generate: openssl rand -hex 32
# ADMIN_ACCESS_TOKEN=

# On-demand cache refresh when Site content is published in Sanity (webhook → POST /api/revalidate)
# Generate: openssl rand -hex 32
# REVALIDATE_SECRET=

# --- Site URL (browser-safe; used for sitemap.xml, robots.txt, canonical/OG URLs) ---
# Set to your production origin (no trailing slash). On Vercel, VERCEL_PROJECT_PRODUCTION_URL
# is used automatically when this is unset; local/preview falls back to the deployment URL.
# NEXT_PUBLIC_SITE_URL=https://design-thinking-seven-mauve.vercel.app

# --- Google Analytics (browser-safe; vanilla GA4 pageview tracking) ---
# Create a GA4 property at https://analytics.google.com and copy the Measurement ID (G-XXXXXXXXXX).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Chromatic (Storybook visual tests; local publish only — CI uses GitHub secret) ---
# Create a project at https://www.chromatic.com and copy the project token.
# CHROMATIC_PROJECT_TOKEN=
